# ── AI Provider (Required) ─────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Autonomous Agent ───────────────────────────────
AUTONOMOUS_AGENT=true          # Start agent on boot
AUTO_INTERVAL_MS=60000         # Decision cycle interval (ms)

# ── Server ─────────────────────────────────────────
PORT=9000

# ── Solana Network ─────────────────────────────────
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Node Configuration ─────────────────────────────
NODE_NAME=my-mesh-node

# ── Optional: IPFS / Pinata ────────────────────────
PINATA_API_KEY=
PINATA_SECRET_KEY=
